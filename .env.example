# ─── MetaVita environment ─────────────────────────────────────

# Core
ENVIRONMENT=development
LOG_LEVEL=info
# Public URL of the web app — used to build invite / password-reset links in emails.
APP_BASE_URL=http://localhost:3000

# Database (Postgres + pgvector)
DATABASE_URL=postgresql+asyncpg://metavita:metavita@localhost:5432/metavita

# Redis (queue / cache)
REDIS_URL=redis://localhost:6379/0

# Object store (MinIO in dev, S3 in prod)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=metavita
S3_REGION=us-east-1

# ─── Security ────────────────────────────────────────────────────────────────
# App-layer encryption key for provider credentials / PHI fields.
# Dev only: a local Fernet key. In prod this is wrapped by KMS/Vault — never commit real keys.
APP_ENCRYPTION_KEY=
# JWT signing secret 
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256

